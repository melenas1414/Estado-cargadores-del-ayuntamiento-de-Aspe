# ═══════════════════════════════════════════════════════════
# .env.example — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ═══════════════════════════════════════════════════════════

# ── Supabase (obligatorio) ──────────────────────────────────
# URL de tu proyecto Supabase (Settings → API → Project URL)
NUXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anónima pública (Settings → API → anon public)
NUXT_PUBLIC_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio (Settings → API → service_role) — SOLO SERVIDOR / GITHUB ACTIONS
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alias para el scraper de GitHub Actions
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # service_role

# ── Iberdrola API (opcional — acceso privado) ────────────────
# Actívala sólo si tienes acceso privado concedido por Iberdrola.
IBERDROLA_API_URL=
IBERDROLA_API_KEY=

# ── Google Places API (New) — fuente principal tiempo real ───
# Habilita EV Charging API en Google Cloud Console y añade la clave aquí.
# Documentación: https://developers.google.com/maps/documentation/places/web-service/ev-charging
# Si no se configura, el sistema usa OpenChargeMap como fallback.
GOOGLE_PLACES_API_KEY=

# ── OpenChargeMap (fuente gratuita principal) ────────────────
# Clave API de OpenChargeMap (opcional, pero aumenta el límite de peticiones).
# Regístrate en https://openchargemap.org/site/developerinfo
OCM_API_KEY=tu_clave_ocm
