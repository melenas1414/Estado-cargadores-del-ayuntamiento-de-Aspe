# ═══════════════════════════════════════════════════════════
# .env.example — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ═══════════════════════════════════════════════════════════

# ── Supabase (obligatorio) ──────────────────────────────────
# URL de tu proyecto Supabase (Settings → API → Project URL)
NUXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anónima pública (Settings → API → anon public)
NUXT_PUBLIC_SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio (Settings → API → service_role) — SOLO SERVIDOR / GITHUB ACTIONS
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Alias para el scraper de GitHub Actions
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Iberdrola API (opcional — acceso privado) ────────────────
# Actívala sólo si tienes acceso privado concedido por Iberdrola.
IBERDROLA_API_URL=
IBERDROLA_API_KEY=

# ── Selección de cargadores visibles en la app (opcional) ─────
# Lista CSV de station_id visibles en /api/chargers/current.
# Si se deja vacío, se muestran todos los station_id disponibles.
# Ejemplo (Aspe + Monforte cercano):
# CHARGERS_VISIBLE_STATION_IDS=ESIBE22E0001001,ESIBE22E0001002,ESIBE22E0001003,ESIBE22E0001004,ESIBE22E0001005,IBERDROLA-5629
CHARGERS_VISIBLE_STATION_IDS=

# ── Selección de estaciones objetivo del scraper (opcional) ───
# Lista CSV de station_id definidos en scripts/iberdrola-scraper.mjs.
# Si se deja vacío, el scraper usa todas las estaciones conocidas.
# Ejemplo:
# SCRAPER_STATION_IDS=ESIBE22E0001001,ESIBE22E0001002,ESIBE22E0001003,ESIBE22E0001004,ESIBE22E0001005,IBERDROLA-5629
SCRAPER_STATION_IDS=

# ── Telegram auth + notificaciones (MVP) ──────────────────────
# Token del bot de Telegram (BotFather)
TELEGRAM_BOT_TOKEN=

# Username público del bot sin @ (visible en cliente para deep-link)
NUXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# ID público del bot (parte numérica del token, para login oficial Telegram)
NUXT_PUBLIC_TELEGRAM_BOT_ID=

# Secreto para firmar/sellar sesiones de login Telegram
TELEGRAM_SESSION_SECRET=

# TTL del challenge OTP de login (segundos)
TELEGRAM_AUTH_CHALLENGE_TTL_SECONDS=600

# TTL de la sesión web tras login (días)
TELEGRAM_SESSION_TTL_DAYS=14

# Secreto compartido para permitir que n8n marque la challenge como verificada
TELEGRAM_CLAIM_SECRET=

# Secreto compartido para proteger /api/notifications/trigger
NOTIFICATION_TRIGGER_SECRET=

# Lista CSV de usuarios prioritarios (telegram_user_id o chat_id)
# Ejemplo: PRIORITY_TELEGRAM_USERS=12345678,987654321
PRIORITY_TELEGRAM_USERS=

# Campo para comparar prioridad: telegram_user_id | telegram_chat_id
PRIORITY_MATCH_FIELD=telegram_user_id

# Espera recomendada entre ola priority y regular (segundos)
PRIORITY_NOTIFY_DELAY_SECONDS=120
